# ================================
# Marketing Agent AD BOT - ENV VARS
# ================================
# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub

# Server
PORT=4000
NODE_ENV=development

# Claude API (Anthropic)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-opus-4-5

# Google Ads API
# Get credentials at: https://developers.google.com/google-ads/api
GOOGLE_ADS_CLIENT_ID=your_google_client_id
GOOGLE_ADS_CLIENT_SECRET=your_google_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_developer_token
GOOGLE_ADS_CUSTOMER_ID=your_google_customer_id

# Meta Ads API
# Get credentials at: https://developers.facebook.com
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_access_token
META_AD_ACCOUNT_ID=act_your_ad_account_id

# Database (PostgreSQL - coming in v2)
DATABASE_URL=postgresql://user:password@localhost:5432/marketing_agent

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
